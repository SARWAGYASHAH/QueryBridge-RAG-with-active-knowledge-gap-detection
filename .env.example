# QueryBridge — Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Groq free tier — get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (default: llama3-8b-8192)
GROQ_MODEL=llama3-8b-8192

# ── Live Search (one or both) ─────────────────────────────────────────────────
# Serper.dev — primary search provider (https://serper.dev)
SERPER_API_KEY=your_serper_api_key_here

# Tavily — fallback search provider (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# ── Vector Store ──────────────────────────────────────────────────────────────
# Local path where ChromaDB persists its data
CHROMA_PERSIST_DIR=chroma_db

# ── Retrieval Settings ────────────────────────────────────────────────────────
# Number of top chunks to retrieve per query
TOP_K=5

# ── Confidence Thresholds ─────────────────────────────────────────────────────
# Score >= HIGH_CONFIDENCE_THRESHOLD  → answer directly
# Score >= SEARCH_TRIGGER_THRESHOLD   → trigger web search
# Score <  SEARCH_TRIGGER_THRESHOLD   → escalate to human
HIGH_CONFIDENCE_THRESHOLD=0.7
SEARCH_TRIGGER_THRESHOLD=0.4

# ── Escalation ────────────────────────────────────────────────────────────────
# File path for the JSON escalation log
ESCALATION_LOG_PATH=data/escalations.json

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
